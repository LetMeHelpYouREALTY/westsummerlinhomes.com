{
  "version": 2,
  "builds": [
    { "src": "index.html", "use": "@vercel/static" },
    { "src": "about.html", "use": "@vercel/static" },
    { "src": "contact.html", "use": "@vercel/static" },
    { "src": "services.html", "use": "@vercel/static" },
    { "src": "sitemap.xml", "use": "@vercel/static" },
    { "src": "robots.txt", "use": "@vercel/static" },
    { "src": "image-cdn.js", "use": "@vercel/static" },
    { "src": "images/**", "use": "@vercel/static" },
    { "src": "properties/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/about", "dest": "/about.html" },
    { "src": "/contact", "dest": "/contact.html" },
    { "src": "/services", "dest": "/services.html" },
    { "src": "/about.html", "dest": "/about.html" },
    { "src": "/contact.html", "dest": "/contact.html" },
    { "src": "/services.html", "dest": "/services.html" },
    { "src": "/sitemap.xml", "dest": "/sitemap.xml" },
    { "src": "/robots.txt", "dest": "/robots.txt" },
    { "src": "/image-cdn.js", "dest": "/image-cdn.js" },
    { "src": "/images/(.*)", "dest": "/images/$1" },
    { "src": "/properties/(.*)", "dest": "/properties/$1" },
    { "src": "/", "dest": "/index.html" }
  ]
}
