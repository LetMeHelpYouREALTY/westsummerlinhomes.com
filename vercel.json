{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "",
  "buildCommand": "",
  "outputDirectory": ".",
  "redirects": [
    {
      "source": "/index.html",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/about",
      "destination": "/about.html",
      "permanent": true
    },
    {
      "source": "/contact",
      "destination": "/contact.html",
      "permanent": true
    },
    {
      "source": "/services",
      "destination": "/services.html",
      "permanent": true
    },
    {
      "source": "/properties",
      "destination": "/properties.html",
      "permanent": true
    },
    {
      "source": "/buyers",
      "destination": "/buyers.html",
      "permanent": true
    },
    {
      "source": "/sellers",
      "destination": "/sellers.html",
      "permanent": true
    },
    {
      "source": "/neighborhoods",
      "destination": "/neighborhoods.html",
      "permanent": true
    },
    {
      "source": "/faq",
      "destination": "/faq.html",
      "permanent": true
    },
    {
      "source": "/luxury-homes",
      "destination": "/luxury-homes.html",
      "permanent": true
    },
    {
      "source": "/market-update",
      "destination": "/market-update.html",
      "permanent": true
    },
    {
      "source": "/home-valuation",
      "destination": "/home-valuation.html",
      "permanent": true
    },
    {
      "source": "/testimonials",
      "destination": "/testimonials.html",
      "permanent": true
    },
    {
      "source": "/red-rock-country-club",
      "destination": "/red-rock-country-club.html",
      "permanent": true
    },
    {
      "source": "/regency-at-summerlin",
      "destination": "/regency-at-summerlin.html",
      "permanent": true
    },
    {
      "source": "/stonebridge-summerlin",
      "destination": "/stonebridge-summerlin.html",
      "permanent": true
    },
    {
      "source": "/summerlin-centre",
      "destination": "/summerlin-centre.html",
      "permanent": true
    },
    {
      "source": "/the-ridges-summerlin",
      "destination": "/the-ridges-summerlin.html",
      "permanent": true
    },
    {
      "source": "/the-trails-summerlin",
      "destination": "/the-trails-summerlin.html",
      "permanent": true
    },
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "westsummerlinhomes.com" }],
      "destination": "https://www.westsummerlinhomes.com/:path*",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/robots.txt",
      "headers": [
        { "key": "Content-Type", "value": "text/plain; charset=utf-8" },
        { "key": "Cache-Control", "value": "public, max-age=3600, must-revalidate" }
      ]
    },
    {
      "source": "/sitemap.xml",
      "headers": [
        { "key": "Content-Type", "value": "application/xml; charset=utf-8" },
        { "key": "Cache-Control", "value": "public, max-age=3600, must-revalidate" }
      ]
    },
    {
      "source": "/site.css",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=3600, must-revalidate" }
      ]
    },
    {
      "source": "/(site|calendly|realscout-loader)\\.js",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/fonts/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/properties/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
